# Database
DATABASE_URL=postgresql://medflow:medflow_secret@localhost:5432/medflow?schema=public

# Backend
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://192.168.1.5:3000,http://3.110.48.102:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_API_PORT=4000
# For a physical Android device on the same Wi-Fi, use:
# NEXT_PUBLIC_API_URL=http://192.168.1.5:4000/api

# File uploads (Cloudinary - optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp Cloud API (placeholders - do not commit real credentials)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=medflow_webhook_verify

# Alert thresholds
EXPIRY_WARNING_DAYS=90
EXPIRY_CRITICAL_DAYS=30
SHORTFALL_THRESHOLD_PERCENT=30
NON_REPORTING_DAYS=7

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Set EMAIL_ENABLED=true to activate transactional email (new-user credentials,
# password resets). Leave false (default) to skip sending — passwords are still
# shown to the admin in the UI and the reset URL is logged to the server console.
EMAIL_ENABLED=false

# SMTP server — required when EMAIL_ENABLED=true.
# Common values: smtp.gmail.com (port 587), smtp.sendgrid.net (port 587),
# smtp.office365.com (port 587), or your organisation's internal relay.
SMTP_HOST=
SMTP_PORT=587         # 587 = STARTTLS (most common), 465 = implicit TLS, 25 = unencrypted
SMTP_USER=
SMTP_PASS=

# Sender identity shown in the From: header.
EMAIL_FROM=noreply@yourdomain.example
EMAIL_FROM_NAME=SCM Solution

# Base URL of the frontend — used to build the login and password-reset links
# inside emails.  Must be the publicly reachable address in production.
APP_BASE_URL=http://localhost:3000
