# Database
DATABASE_URL=postgresql://medflow:medflow_secret@localhost:5432/medflow?schema=public

# Backend
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://192.168.1.5:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_API_PORT=4000
# For a physical Android device on the same Wi-Fi, use:
# NEXT_PUBLIC_API_URL=http://192.168.1.5:4000/api

# File uploads (Cloudinary - optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp Cloud API (placeholders - do not commit real credentials)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=medflow_webhook_verify

# Alert thresholds
EXPIRY_WARNING_DAYS=90
EXPIRY_CRITICAL_DAYS=30
SHORTFALL_THRESHOLD_PERCENT=30
NON_REPORTING_DAYS=7
